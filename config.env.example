# =============================================================================
# xray-logs-collector — configuration
# Copy to config.env, fill in values, then run: ./xray-logs-collector.sh collect
# =============================================================================

# --- Remnawave panel API (для динамического списка нод) ---
PANEL_URL="https://panel.example.com"
PANEL_TOKEN=""

# --- SSH (для подключения к нодам) ---
SSH_KEY_PATH="/root/.ssh/xray_logs_collector"
SSH_USER="root"
SSH_PORT=22
SSH_TIMEOUT=15

# Переопределение пользователя для конкретных нод (формат: "ip:user ip:user", через пробел)
SSH_USER_OVERRIDES=""

# --- Пути на нодах ---
REMOTE_LOG_DIR="/var/log/remnanode"

# --- Timeweb S3 ---
S3_ENDPOINT_URL="https://s3.twcstorage.ru"
S3_REGION="ru-1"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET=""
# Префикс для ключей S3. Структура: <prefix><node-ip>/<YYYY>/<MM>/<filename>
S3_PREFIX="xray-logs/"

# --- Telegram уведомления (необязательно — оставь пустым чтобы выключить) ---
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
TELEGRAM_TOPIC_ID=""

# --- Локальные пути ---
TMP_DIR="/var/tmp/xray-logs-collector"
LOG_FILE="/var/log/rw-xray-logs.log"
LOCK_FILE="/var/run/xray-logs-collector.lock"

# --- Параллелизм (сколько нод обрабатывать одновременно) ---
PARALLEL_JOBS=4
